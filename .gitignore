# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# local temp app
tempapp/

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

.vercel
.env*.local

# Orderry API response dumps (debug / data, possible PII)
/ops*.json
/order.json

# ISP scraper artifacts (secrets / debug)
scripts/.isp_auth_state.json
scripts/_isp_debug.html
scripts/_isp_debug.png
scripts/_isp_debug_frame.html
scripts/_test_env.py
scripts/__pycache__/
**/__pycache__/
*.pyc
.next-dev/
